'use client';

import { useState } from 'react';
import { cn } from '@/lib/utils/cn';
import { toggleFundamental } from '@/actions/today';
import { FUNDAMENTALS } from '@/lib/constants';
import type { Fundamental } from '@/lib/types/database';

interface FundamentalsTrackerProps {
  fundamentals: Fundamental;
}

export function FundamentalsTracker({ fundamentals }: FundamentalsTrackerProps) {
  const [state, setState] = useState(fundamentals);

  async function handleToggle(key: string) {
    const currentValue = state[key as keyof typeof state] as boolean;
    const newValue = !currentValue;
    setState((prev) => ({ ...prev, [key]: newValue }));
    await toggleFundamental(key, newValue);
  }

  const hitCount = FUNDAMENTALS.filter(
    (f) => state[f.key as keyof typeof state]
  ).length;

  return (
    <div className="space-y-3">
      <div className="flex items-center justify-between">
        <p className="text-[10px] font-medium text-text-tertiary uppercase tracking-widest">
          Fundamentals
        </p>
        <p className="text-[10px] text-text-tertiary">
          {hitCount}/{FUNDAMENTALS.length}
        </p>
      </div>

      <div className="grid grid-cols-2 gap-0.5">
        {FUNDAMENTALS.map((fundamental) => {
          const checked = state[fundamental.key as keyof typeof state] as boolean;
          return (
            <button
              key={fundamental.key}
              onClick={() => handleToggle(fundamental.key)}
              className={cn(
                'flex items-center gap-2.5 py-2.5 px-3 transition-all text-left',
                'hover:bg-surface-secondary',
                checked && 'bg-accent/5'
              )}
            >
              <div
                className={cn(
                  'w-4 h-4 border flex-shrink-0 flex items-center justify-center transition-all',
                  checked
                    ? 'bg-accent border-accent'
                    : 'border-border-light'
                )}
              >
                {checked && (
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M2 6L5 9L10 3" stroke="black" strokeWidth="2" strokeLinecap="square" />
                  </svg>
                )}
              </div>
              <span
                className={cn(
                  'text-xs transition-colors',
                  checked ? 'text-text-primary' : 'text-text-secondary'
                )}
              >
                {fundamental.label}
              </span>
            </button>
          );
        })}
      </div>
    </div>
  );
}
